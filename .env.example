# ClockInn-Pro environment variables
# Copy to .env and fill in real values.
# IMPORTANT: This file must never contain real secrets — only variable names and safe example/placeholder values.

# --- Database ---
# Use host "db" only when the API runs INSIDE Docker (docker-compose) and you use the local db service.
# Use "localhost" when the API runs on your host and Postgres is local.
# Use Supabase URI when migrating to Supabase (see docs/MIGRATE_TO_SUPABASE.md).

# Docker (API in container, local Postgres):
# DATABASE_URL=postgresql://clockinn:YOUR_PASSWORD@db:5432/clockinn

# Local (API on host, Postgres on host or in Docker with port 5432):
DATABASE_URL=postgresql://clockinn:YOUR_PASSWORD@localhost:5432/clockinn

# Supabase (replace with your project's URI from Dashboard → Settings → Database):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# For connection pooler (e.g. serverless): use Transaction mode URI on port 6543

# --- Runtime ---
# Set to production (or prod) in production: generic API errors, no /health/test-error, HTTPS redirect in API middleware.
# ENVIRONMENT=production

# --- Auth ---
SECRET_KEY=your-secret-key-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_ABSOLUTE_MAX_DAYS=30

# Refresh token is set in an HttpOnly cookie. Set COOKIE_SECURE=true when using HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_NAME=refresh_token
# Optional; if set, use the same value in production (e.g. .app.example.com for API + SPA subdomains).
# COOKIE_DOMAIN=

# --- Login lockout (optional Redis for multiple API replicas) ---
# Leave unset to use in-process memory (fine for single instance).
# Example with Docker Compose Redis: REDIS_URL=redis://redis:6379/0
# REDIS_URL=
# LOGIN_LOCKOUT_USE_IP=false
# LOGIN_LOCKOUT_REDIS_ATTEMPT_TTL_SECONDS=86400

# --- CORS / Frontend ---
# List only origins your browser app is served from (scheme + host + port). Comma-separated or JSON array.
# With credentials (cookies), browsers require an explicit list — never use *.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Client (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Docker Compose (optional; used when running docker-compose) ---
# POSTGRES_USER=clockinn
# POSTGRES_PASSWORD=your-password
# POSTGRES_DB=clockinn

# --- Gmail API (optional; for verification/schedule emails) ---
# GMAIL_CREDENTIALS_JSON=   # JSON string of OAuth client credentials
# GMAIL_TOKEN_JSON=        # JSON string of OAuth token (do not commit real tokens)
# GMAIL_SENDER_EMAIL=no-reply@example.com

# --- Production ---
# ENVIRONMENT=production   # or prod — enables strict CORS checks below, generic errors, HTTPS redirect, etc.
# COOKIE_SECURE=true
# CORS_ORIGINS=https://app.yourdomain.com
# Multiple front-ends: comma-separated HTTPS origins only (http:// allowed only for localhost / 127.0.0.1).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
